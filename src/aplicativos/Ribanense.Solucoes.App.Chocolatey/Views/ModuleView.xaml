<UserControl x:Class="Ribanense.Solucoes.App.Chocolatey.Views.ModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Ribanense.Solucoes.App.Chocolatey.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:ModuleViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <DockPanel LastChildFill="True">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Módulo Chocolatey"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.Text}" />
                <TextBlock Foreground="{StaticResource Brush.TextMuted}"
                           Margin="0,2,0,0"
                           Text="{Binding StatusMessage}" />
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Verificar"
                    Style="{StaticResource Button.Base}"
                    Command="{Binding InspectCommand}" />
        </Grid>

        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource Brush.LogBg}"
                MaxHeight="200"
                Margin="0,12,0,0">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Background="#2B2B2B">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Log do modulo"
                               Foreground="{StaticResource Brush.LogText}"
                               VerticalAlignment="Center"
                               Margin="12,6" />
                    <Button Grid.Column="1"
                            Content="Copiar"
                            Style="{StaticResource Button.Base}"
                            Margin="6"
                            Command="{Binding CopyLogCommand}" />
                </Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding LogLines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           Foreground="{StaticResource Brush.LogText}"
                                           Margin="12,1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Margin="0,0,0,8"
                           Text="{Binding HealthyLabel}"
                           Foreground="{StaticResource Brush.Text}" />

                <Border Style="{StaticResource Badge.Surface}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.BadgeTitle}" Text="Chocolatey CLI" />
                        <TextBlock Text="{Binding ChocolateyLine}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Badge.Surface}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Text.BadgeTitle}" Text="Permissões" />
                        <TextBlock Text="{Binding AdminLine}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
