<UserControl x:Class="Ribanense.Solucoes.App.Chocolatey.Views.SourcesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Ribanense.Solucoes.App.Chocolatey.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:SourcesViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <DockPanel LastChildFill="True">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Fontes Chocolatey"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.Text}" />
                <TextBlock Foreground="{StaticResource Brush.TextMuted}"
                           Margin="0,2,0,0"
                           Text="{Binding StatusMessage}" />
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Recarregar"
                    Style="{StaticResource Button.Base}"
                    Command="{Binding RefreshCommand}" />
        </Grid>

        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource Brush.LogBg}"
                MaxHeight="180"
                Margin="0,12,0,0">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Background="#2B2B2B">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Log de fontes"
                               Foreground="{StaticResource Brush.LogText}"
                               VerticalAlignment="Center"
                               Margin="12,6" />
                    <Button Grid.Column="1"
                            Content="Copiar"
                            Style="{StaticResource Button.Base}"
                            Margin="6"
                            Command="{Binding CopyLogCommand}" />
                </Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding LogLines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           Foreground="{StaticResource Brush.LogText}"
                                           Margin="12,1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <DataGrid ItemsSource="{Binding Rows}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="*" MinWidth="120" />
                <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="3*" MinWidth="260" />
                <DataGridTextColumn Header="Desabilitada" Binding="{Binding Disabled}" Width="Auto" MinWidth="100" />
                <DataGridTextColumn Header="Prioridade" Binding="{Binding Priority}" Width="Auto" MinWidth="80" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="2*" MinWidth="120" />
                <DataGridTemplateColumn Header="" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Remover"
                                    Style="{StaticResource Button.Danger}"
                                    Margin="6,2"
                                    Command="{Binding RemoveCommand}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
