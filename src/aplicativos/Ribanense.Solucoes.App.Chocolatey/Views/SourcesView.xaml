<UserControl x:Class="Ribanense.Solucoes.App.Chocolatey.Views.SourcesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Ribanense.Solucoes.App.Chocolatey.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:SourcesViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <DockPanel LastChildFill="True">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Fontes Chocolatey"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.Text}" />
                <TextBlock Foreground="{StaticResource Brush.TextMuted}"
                           Margin="0,2,0,0"
                           Text="{Binding StatusMessage}" />
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Recarregar"
                    Style="{StaticResource Button.Base}"
                    Command="{Binding RefreshCommand}" />
        </Grid>

        <DataGrid ItemsSource="{Binding Rows}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="*" MinWidth="80" />
                <DataGridTextColumn Header="URL" Binding="{Binding Url}" Width="*" MinWidth="80" />
                <DataGridTextColumn Header="Desabilitada" Binding="{Binding Disabled}" Width="*" MinWidth="80" />
                <DataGridTextColumn Header="Prioridade" Binding="{Binding Priority}" Width="*" MinWidth="80" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*" MinWidth="80" />
                <DataGridTemplateColumn Header="" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Remover"
                                    Style="{StaticResource Button.Danger}"
                                    Margin="6,2"
                                    Command="{Binding RemoveCommand}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
