<Application x:Class="Ribanense.Solucoes.App.Sistema.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Ribanense.Solucoes.App.Sistema.Converters"
             xmlns:vm="clr-namespace:Ribanense.Solucoes.App.Sistema.ViewModels"
             xmlns:views="clr-namespace:Ribanense.Solucoes.App.Sistema.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Ribanense.Solucoes.App.Sistema;component/Resources/Theme.xaml" />
                <ResourceDictionary Source="/Ribanense.Solucoes.UI;component/Styles/Breakpoints.xaml" />
                <ResourceDictionary Source="/Ribanense.Solucoes.UI;component/Styles/DataGrid.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />

            <DataTemplate DataType="{x:Type vm:ActivationViewModel}">
                <views:ActivationView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
