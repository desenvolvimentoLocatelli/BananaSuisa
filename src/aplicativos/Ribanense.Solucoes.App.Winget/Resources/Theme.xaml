<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Brush.Background" Color="#F3F3F3" />
    <SolidColorBrush x:Key="Brush.Surface"    Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Border"     Color="#E0E0E0" />
    <SolidColorBrush x:Key="Brush.Text"       Color="#1C1C1C" />
    <SolidColorBrush x:Key="Brush.TextMuted"  Color="#6B6B6B" />
    <SolidColorBrush x:Key="Brush.Accent"     Color="#2E6FDB" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#275FC0" />
    <SolidColorBrush x:Key="Brush.AccentDisabled" Color="#B8C8E6" />
    <SolidColorBrush x:Key="Brush.Danger"     Color="#C23B22" />
    <SolidColorBrush x:Key="Brush.Success"    Color="#27864E" />
    <SolidColorBrush x:Key="Brush.Warning"    Color="#B5791A" />
    <SolidColorBrush x:Key="Brush.Success.Bg" Color="#E9F7EE" />
    <SolidColorBrush x:Key="Brush.Warning.Bg" Color="#FDF5E3" />
    <SolidColorBrush x:Key="Brush.Danger.Bg"  Color="#FBE9E7" />
    <SolidColorBrush x:Key="Brush.SidebarBg"  Color="#ECECEC" />
    <SolidColorBrush x:Key="Brush.SidebarSelected" Color="#DCDCDC" />
    <SolidColorBrush x:Key="Brush.SidebarHover" Color="#E0E0E0" />
    <SolidColorBrush x:Key="Brush.LogBg"      Color="#1E1E1E" />
    <SolidColorBrush x:Key="Brush.LogText"    Color="#EAEAEA" />

    <Style x:Key="Button.Base" TargetType="Button">
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Button.Accent" TargetType="Button" BasedOn="{StaticResource Button.Base}">
        <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
    </Style>

    <Style x:Key="Button.Danger" TargetType="Button" BasedOn="{StaticResource Button.Base}">
        <Setter Property="Background" Value="{StaticResource Brush.Danger}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Danger}" />
    </Style>

    <Style x:Key="Tab.Toggle" TargetType="RadioButton">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0,0,0,2"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.SidebarHover}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Badge.Surface" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="Badge.Success" TargetType="Border" BasedOn="{StaticResource Badge.Surface}">
        <Setter Property="Background" Value="{StaticResource Brush.Success.Bg}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Success}" />
    </Style>

    <Style x:Key="Badge.Warning" TargetType="Border" BasedOn="{StaticResource Badge.Surface}">
        <Setter Property="Background" Value="{StaticResource Brush.Warning.Bg}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Warning}" />
    </Style>

    <Style x:Key="Badge.Danger" TargetType="Border" BasedOn="{StaticResource Badge.Surface}">
        <Setter Property="Background" Value="{StaticResource Brush.Danger.Bg}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Danger}" />
    </Style>

    <Style x:Key="Text.BadgeTitle" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
    </Style>

</ResourceDictionary>
