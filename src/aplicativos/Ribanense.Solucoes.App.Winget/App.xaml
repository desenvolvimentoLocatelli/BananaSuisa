<Application x:Class="Ribanense.Solucoes.App.Winget.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Ribanense.Solucoes.App.Winget.Converters"
             xmlns:vm="clr-namespace:Ribanense.Solucoes.App.Winget.ViewModels"
             xmlns:views="clr-namespace:Ribanense.Solucoes.App.Winget.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Ribanense.Solucoes.App.Winget;component/Resources/Theme.xaml" />
                <ResourceDictionary Source="/Ribanense.Solucoes.UI;component/Styles/Breakpoints.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />

            <DataTemplate DataType="{x:Type vm:SearchViewModel}">
                <views:SearchView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:InstalledViewModel}">
                <views:InstalledView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
