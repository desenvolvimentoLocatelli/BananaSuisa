<UserControl x:Class="Ribanense.Solucoes.App.Winget.Views.SourcesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Ribanense.Solucoes.App.Winget.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:SourcesViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <DockPanel LastChildFill="True">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Repositorios (fontes)"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.Text}" />
                <TextBlock Foreground="{StaticResource Brush.TextMuted}"
                           Margin="0,2,0,0"
                           Text="{Binding StatusMessage}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Recarregar"
                        Style="{StaticResource Button.Base}"
                        Margin="0,0,6,0"
                        Command="{Binding RefreshCommand}" />
                <Button Content="Atualizar todas"
                        Style="{StaticResource Button.Base}"
                        Margin="0,0,6,0"
                        Command="{Binding RefreshAllSourcesCommand}" />
                <Button Content="Adicionar..."
                        Style="{StaticResource Button.Accent}"
                        Margin="0,0,6,0"
                        Command="{Binding AddNewCommand}" />
                <Button Content="Restaurar padrao (UAC)"
                        Style="{StaticResource Button.Danger}"
                        Command="{Binding ResetAllCommand}" />
            </StackPanel>
        </Grid>

        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource Brush.LogBg}"
                MaxHeight="180"
                Margin="0,12,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding LogLines}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Foreground="{StaticResource Brush.LogText}"
                                       Margin="12,1" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <DataGrid ItemsSource="{Binding Rows}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nome"     Binding="{Binding Name}"       Width="*" MinWidth="120" />
                <DataGridTextColumn Header="URL / Arg" Binding="{Binding Argument}"  Width="3*" MinWidth="260" />
                <DataGridTextColumn Header="Tipo"     Binding="{Binding Type}"       Width="Auto" MinWidth="150" />
                <DataGridTextColumn Header="Confianca" Binding="{Binding TrustLevel}" Width="Auto" MinWidth="80" />
                <DataGridTextColumn Header="Status"   Binding="{Binding Status}"     Width="2*" MinWidth="120" />
                <DataGridTemplateColumn Header="" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Atualizar"
                                        Style="{StaticResource Button.Base}"
                                        Margin="6,2,4,2"
                                        Command="{Binding UpdateCommand}" />
                                <Button Content="Remover"
                                        Style="{StaticResource Button.Danger}"
                                        Margin="4,2,6,2"
                                        Command="{Binding RemoveCommand}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
