<UserControl x:Class="Ribanense.Solucoes.App.Winget.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Ribanense.Solucoes.App.Winget.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:SearchViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <DockPanel LastChildFill="True">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     FontSize="14"
                     Padding="10,6"
                     VerticalContentAlignment="Center"
                     Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding SearchCommand}" />
                </TextBox.InputBindings>
            </TextBox>
            <Button Grid.Column="1"
                    Margin="8,0,0,0"
                    Content="Buscar"
                    Style="{StaticResource Button.Accent}"
                    Command="{Binding SearchCommand}" />
        </Grid>

        <TextBlock DockPanel.Dock="Top"
                   Margin="0,0,0,8"
                   Foreground="{StaticResource Brush.TextMuted}"
                   Text="{Binding StatusMessage}" />

        <StackPanel DockPanel.Dock="Top"
                    Margin="0,0,0,16"
                    Visibility="{Binding ShowSuggested, Converter={StaticResource BoolToVis}}">
            <TextBlock FontSize="15"
                       FontWeight="SemiBold"
                       Text="Sugeridos auditados" />
            <TextBlock Margin="0,4,0,8"
                       Foreground="{StaticResource Brush.TextMuted}"
                       Text="Aplicativos populares verificados no catálogo winget. Instale com um clique ou use a busca acima."
                       TextWrapping="Wrap" />
            <ScrollViewer MaxHeight="260"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding SuggestedPackages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock FontWeight="SemiBold"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Foreground="{StaticResource Brush.TextMuted}"
                                               FontSize="12"
                                               Text="{Binding Id}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Margin="12,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource Brush.TextMuted}"
                                           Text="{Binding Category}" />
                                <Button Grid.Column="2"
                                        Content="Instalar"
                                        Style="{StaticResource Button.Accent}"
                                        Margin="6,2"
                                        Command="{Binding InstallCommand}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Results}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="*" MinWidth="80" />
                <DataGridTextColumn Header="Id"   Binding="{Binding Id}"   Width="*" MinWidth="80" />
                <DataGridTextColumn Header="Versão" Binding="{Binding Version}" Width="*" MinWidth="80" />
                <DataGridTextColumn Header="Origem" Binding="{Binding Source}"  Width="*" MinWidth="80" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}"  Width="*" MinWidth="80" />
                <DataGridTemplateColumn Header="" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Instalar"
                                    Style="{StaticResource Button.Accent}"
                                    Margin="6,2"
                                    Command="{Binding InstallCommand}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
