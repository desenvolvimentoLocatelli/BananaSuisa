<Window x:Class="Ribanense.Solucoes.App.Winget.Views.Dialogs.AddSourceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adicionar fonte"
        Width="460"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource Brush.Background}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Adicionar nova fonte"
                   FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource Brush.Text}" />

        <TextBlock Grid.Row="1" Margin="0,12,0,4" Text="Nome" Foreground="{StaticResource Brush.TextMuted}" />
        <TextBox Grid.Row="2" x:Name="NameBox" Padding="8,6" />

        <TextBlock Grid.Row="3" Margin="0,12,0,4" Text="URL / argumento" Foreground="{StaticResource Brush.TextMuted}" />
        <TextBox Grid.Row="4" x:Name="ArgBox" Padding="8,6" />

        <TextBlock Grid.Row="5" Margin="0,12,0,4" Text="Tipo (default: Microsoft.PreIndexed.Package)" Foreground="{StaticResource Brush.TextMuted}" />
        <TextBox Grid.Row="6" x:Name="TypeBox" Padding="8,6" Text="Microsoft.PreIndexed.Package" />

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancelar"
                    Style="{StaticResource Button.Base}"
                    IsCancel="True"
                    Margin="0,0,8,0"
                    Click="OnCancel" />
            <Button Content="Adicionar"
                    Style="{StaticResource Button.Accent}"
                    IsDefault="True"
                    Click="OnAccept" />
        </StackPanel>
    </Grid>
</Window>
