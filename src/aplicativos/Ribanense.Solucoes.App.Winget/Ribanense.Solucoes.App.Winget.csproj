  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Resources\aliases.json" LogicalName="Ribanense.Solucoes.App.Winget.aliases.json" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Ribanense.Solucoes.App.Winget.Tests" />
  </ItemGroup>
</Project>
