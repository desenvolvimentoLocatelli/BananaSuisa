<UserControl x:Class="Ribanense.Solucoes.Launcher.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Ribanense.Solucoes.Launcher.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:AboutViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Sobre"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.Text}" />

            <Border Style="{StaticResource Card.Surface}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Ribanense Soluções" Style="{StaticResource Text.Title}" />
                    <TextBlock Style="{StaticResource Text.Muted}"
                               Margin="0,4,0,0"
                               Text="{Binding VersionsLine, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card.Surface}">
                <StackPanel>
                    <TextBlock Text="Atualização do launcher" Style="{StaticResource Text.Title}" />

                    <TextBlock Style="{StaticResource Text.Muted}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding UpdateBannerText, Mode=OneWay}"
                               Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibility}}" />

                    <TextBlock Style="{StaticResource Text.Body}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding UpdateMessage, Mode=OneWay}"
                               Visibility="{Binding UpdateMessage, Converter={StaticResource NullToVisibility}}" />

                    <TextBlock Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource Brush.Danger}"
                               Text="{Binding UpdateError, Mode=OneWay}"
                               Visibility="{Binding UpdateError, Converter={StaticResource NullToVisibility}}" />

                    <ProgressBar Height="8" Margin="0,10,0,0"
                                 Minimum="0" Maximum="100"
                                 Value="{Binding UpdateProgress, Mode=OneWay}"
                                 Visibility="{Binding IsUpdating, Converter={StaticResource BoolToVisibility}}" />

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="Verificar atualização"
                                Style="{StaticResource Button.Base}"
                                Command="{Binding CheckUpdateCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Atualizar e reiniciar"
                                Style="{StaticResource Button.Accent}"
                                Command="{Binding UpdateLauncherCommand}"
                                Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card.Surface}">
                <StackPanel>
                    <TextBlock Text="Configuração" Style="{StaticResource Text.Title}" />

                    <TextBlock Style="{StaticResource Text.Muted}" Margin="0,8,0,0" Text="Catálogo:" />
                    <TextBlock Style="{StaticResource Text.Body}"
                               Text="{Binding CatalogUrl, Mode=OneWay}"
                               TextWrapping="Wrap" />

                    <TextBlock Style="{StaticResource Text.Muted}" Margin="0,8,0,0" Text="Pasta de dados:" />
                    <TextBlock Style="{StaticResource Text.Body}"
                               Text="{Binding DataRoot, Mode=OneWay}"
                               TextWrapping="Wrap" />

                    <TextBlock Style="{StaticResource Text.Muted}" Margin="0,8,0,0" Text="Pasta de aplicativos:" />
                    <TextBlock Style="{StaticResource Text.Body}"
                               Text="{Binding AplicativosRoot, Mode=OneWay}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <TextBlock Style="{StaticResource Text.Muted}"
                       Margin="0,12,0,0"
                       TextWrapping="Wrap"
                       Text="Configurável via variáveis de ambiente: RIBANENSE_CATALOG_URL, RIBANENSE_LAUNCHER_DATA, RIBANENSE_APLICATIVOS_ROOT." />
        </StackPanel>
    </ScrollViewer>
</UserControl>
