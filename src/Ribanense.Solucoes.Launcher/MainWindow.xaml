<Window x:Class="Ribanense.Solucoes.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Ribanense.Solucoes.Launcher.ViewModels"
        xmlns:b="clr-namespace:Ribanense.Solucoes.UI.Behaviors;assembly=Ribanense.Solucoes.UI"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
        Title="Ribanense Soluções"
        MinWidth="{StaticResource Breakpoint.MinWindowWidth}"
        MinHeight="{StaticResource Breakpoint.MinWindowHeight}"
        Width="1200"
        Height="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.Background}"
        b:WindowBreakpoints.Enabled="True">

    <Grid>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="Layout">
                <VisualState x:Name="Compact">
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="Sidebar"
                                         Storyboard.TargetProperty="Width"
                                         To="64" Duration="0" />
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="Medium">
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="Sidebar"
                                         Storyboard.TargetProperty="Width"
                                         To="200" Duration="0" />
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="Wide">
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="Sidebar"
                                         Storyboard.TargetProperty="Width"
                                         To="240" Duration="0" />
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Topbar -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1"
                Padding="20,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding ProductName}"
                           FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.Text}" />
            </StackPanel>
        </Border>

        <!-- Sidebar -->
        <Border x:Name="Sidebar" Grid.Row="1" Grid.Column="0"
                Width="240"
                Background="{StaticResource Brush.SidebarBg}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="8,12">
                <RadioButton Style="{StaticResource Button.Sidebar}"
                             GroupName="Nav"
                             IsChecked="True"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="{Binding CatalogPage}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🗂" FontSize="16" Width="24" />
                        <TextBlock Text="Catálogo" VerticalAlignment="Center" />
                    </StackPanel>
                </RadioButton>

                <RadioButton Style="{StaticResource Button.Sidebar}"
                             GroupName="Nav"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="{Binding MyAppsPage}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📦" FontSize="16" Width="24" />
                        <TextBlock Text="Meus apps" VerticalAlignment="Center" />
                    </StackPanel>
                </RadioButton>

                <RadioButton Style="{StaticResource Button.Sidebar}"
                             GroupName="Nav"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="{Binding UpdatesPage}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⬆" FontSize="16" Width="24" />
                        <TextBlock Text="Atualizações" VerticalAlignment="Center" />
                    </StackPanel>
                </RadioButton>

                <RadioButton Style="{StaticResource Button.Sidebar}"
                             GroupName="Nav"
                             Command="{Binding NavigateCommand}"
                             CommandParameter="{Binding AboutPage}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ℹ" FontSize="16" Width="24" />
                        <TextBlock Text="Sobre" VerticalAlignment="Center" />
                    </StackPanel>
                </RadioButton>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ContentControl Grid.Row="1" Grid.Column="1"
                        Content="{Binding CurrentPage}"
                        Margin="24" />
    </Grid>
</Window>
