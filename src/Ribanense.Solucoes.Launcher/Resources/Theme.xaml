<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- Cores base inspiradas em Fluent Design dark-light neutro. -->
    <SolidColorBrush x:Key="Brush.Background"   Color="#F3F3F3" />
    <SolidColorBrush x:Key="Brush.Surface"      Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt"   Color="#FAFAFA" />
    <SolidColorBrush x:Key="Brush.Border"       Color="#E0E0E0" />
    <SolidColorBrush x:Key="Brush.Text"         Color="#1C1C1C" />
    <SolidColorBrush x:Key="Brush.TextMuted"    Color="#6B6B6B" />
    <SolidColorBrush x:Key="Brush.Accent"       Color="#2E6FDB" />
    <SolidColorBrush x:Key="Brush.AccentHover"  Color="#275FC0" />
    <SolidColorBrush x:Key="Brush.AccentDisabled" Color="#B8C8E6" />
    <SolidColorBrush x:Key="Brush.Danger"       Color="#C23B22" />
    <SolidColorBrush x:Key="Brush.Success"      Color="#27864E" />
    <SolidColorBrush x:Key="Brush.Warning"      Color="#B5791A" />
    <SolidColorBrush x:Key="Brush.SidebarBg"    Color="#ECECEC" />
    <SolidColorBrush x:Key="Brush.SidebarHover" Color="#E0E0E0" />
    <SolidColorBrush x:Key="Brush.SidebarSelected" Color="#DCDCDC" />

    <CornerRadius x:Key="Radius.Small">4</CornerRadius>
    <CornerRadius x:Key="Radius.Medium">8</CornerRadius>

    <!-- Botão base -->
    <Style x:Key="Button.Base" TargetType="Button">
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Button.Accent" TargetType="Button" BasedOn="{StaticResource Button.Base}">
        <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="White"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.AccentHover}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Brush.AccentHover}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.AccentDisabled}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Brush.AccentDisabled}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Button.Sidebar" TargetType="RadioButton">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.SidebarHover}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.SidebarSelected}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Card base para listas de apps -->
    <Style x:Key="Card.Surface" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Medium}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <!-- Texto -->
    <Style x:Key="Text.Title" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
    </Style>
    <Style x:Key="Text.Muted" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style x:Key="Text.Body" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text}" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style x:Key="Text.Badge" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
    </Style>

</ResourceDictionary>
