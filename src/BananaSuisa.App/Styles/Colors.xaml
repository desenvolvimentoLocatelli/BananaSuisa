<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background Colors -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#111827" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1F2937" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="WidgetBackgroundBrush" Color="#0F172A" />

    <!-- Border Colors -->
    <SolidColorBrush x:Key="CardBorderBrush" Color="#374151" />
    <SolidColorBrush x:Key="WidgetBorderBrush" Color="#334155" />
    <SolidColorBrush x:Key="SidebarBorderBrush" Color="#1E293B" />

    <!-- Text Colors -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F9FAFB" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#CBD5E1" />
    <SolidColorBrush x:Key="TextHighlightBrush" Color="#93C5FD" />

    <!-- Brand / Accent Colors -->
    <SolidColorBrush x:Key="AccentBrush" Color="#1E3A8A" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#10B981" />
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444" />

</ResourceDictionary>