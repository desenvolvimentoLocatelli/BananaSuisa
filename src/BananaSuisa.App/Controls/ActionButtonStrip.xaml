<UserControl x:Class="BananaSuisa.App.Controls.ActionButtonStrip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignWidth="400" d:DesignHeight="50"
             Margin="0,8,0,0">
    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
        <Button x:Name="SecondaryBtn"
                MinWidth="140"
                Style="{StaticResource ToolbarActionButtonStyle}"
                Content="{Binding SecondaryButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Command="{Binding SecondaryButtonCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        
        <Button x:Name="PrimaryBtn"
                MinWidth="140"
                Margin="8,0,0,0"
                Style="{StaticResource ToolbarActionButtonStyle}"
                Content="{Binding PrimaryButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                Command="{Binding PrimaryButtonCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
    </StackPanel>
</UserControl>
