<UserControl x:Class="BananaSuisa.App.Controls.InstallRetrySummaryDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="540" d:DesignHeight="460">
    <Border Background="#CC1a1f2e"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Border Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource WidgetBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="480"
                MaxWidth="680"
                MaxHeight="520"
                Padding="28,24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" MinHeight="80" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Text="Resumo da instalação" />

                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="Sucesso: " />
                        <Run Text="{Binding BatchSucceededCount, Mode=OneWay}" FontWeight="SemiBold" Foreground="#22c55e" />
                        <Run Text="  |  Falhas: " />
                        <Run Text="{Binding BatchFailedCount, Mode=OneWay}" FontWeight="SemiBold" Foreground="#ef4444" />
                    </TextBlock>
                </StackPanel>

                <DataGrid Grid.Row="4"
                          Style="{StaticResource LogsDataGridStyle}"
                          ItemsSource="{Binding RetryCandidates}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          MaxHeight="280"
                          VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="36" Header="" IsReadOnly="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding IsApproved, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              IsEnabled="{Binding HasSuggestion}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Original" Binding="{Binding OriginalName}" Width="*" MinWidth="100" IsReadOnly="True" />
                        <DataGridTextColumn Header="Sugestão" Binding="{Binding SuggestedName}" Width="*" MinWidth="100" IsReadOnly="True" />
                        <DataGridTextColumn Header="ID sugerido" Binding="{Binding SuggestedId}" Width="140" IsReadOnly="True" />
                        <DataGridTextColumn Header="Status" Binding="{Binding RetryStatus}" Width="80" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Fechar"
                            Style="{StaticResource ToolbarActionButtonStyle}"
                            Margin="0,0,8,0"
                            Command="{Binding CloseRetrySummaryCommand}" />
                    <Button Content="Tentar todos sugeridos"
                            Style="{StaticResource ToolbarActionButtonStyle}"
                            Margin="0,0,8,0"
                            Command="{Binding RetryAllSuggestedCommand}" />
                    <Button Content="Revisar um por um"
                            Style="{StaticResource ToolbarActionButtonStyle}"
                            Command="{Binding RetryOneByOneCommand}" />
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</UserControl>
