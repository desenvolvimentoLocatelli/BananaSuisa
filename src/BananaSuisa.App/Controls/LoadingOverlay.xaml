<UserControl x:Class="BananaSuisa.App.Controls.LoadingOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="root" Background="#B2111827">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel>
            <ProgressBar IsIndeterminate="True" Width="40" Height="40" Foreground="{StaticResource AccentBrush}" Background="{StaticResource CardBackgroundBrush}" BorderThickness="0" />
            <TextBlock Text="{Binding Message, ElementName=root}" Margin="0,16,0,0" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" />
        </StackPanel>
    </Grid>
</UserControl>