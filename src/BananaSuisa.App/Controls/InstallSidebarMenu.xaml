<UserControl x:Class="BananaSuisa.App.Controls.InstallSidebarMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SidebarBackgroundBrush}"
             BorderBrush="{StaticResource SidebarBorderBrush}" BorderThickness="0,0,1,0">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="20,24,20,16">
            <Image Source="pack://application:,,,/Assets/BananaSuisa.png" Width="32" Height="32" VerticalAlignment="Center" Margin="0,0,12,0" />
            <TextBlock Text="Apps" Foreground="{StaticResource TextHighlightBrush}" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" TextWrapping="Wrap" />
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,4,0">
        <StackPanel Background="Transparent">
            <Rectangle Height="1" Margin="12,0,12,12" Fill="{StaticResource SidebarBorderBrush}" />

            <Button Content="Apps · visão geral" Command="{Binding NavigateInstallSubCommand}" CommandParameter="InstallOverview">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding InstallSubKey}" Value="InstallOverview">
                                <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Margin="0,6,0,0" Content="Apps · instalar" Command="{Binding NavigateInstallSubCommand}" CommandParameter="InstallRun">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding InstallSubKey}" Value="InstallRun">
                                <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Margin="0,6,0,0" Content="Apps · desinstalar" Command="{Binding NavigateInstallSubCommand}" CommandParameter="InstallUninstall">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding InstallSubKey}" Value="InstallUninstall">
                                <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2"
                Margin="12,8,12,16"
                Padding="16,12"
                HorizontalContentAlignment="Left"
                Content="← Voltar ao menu"
                Command="{Binding ExitInstallModeCommand}"
                Style="{StaticResource SidebarButtonStyle}"
                Foreground="{StaticResource TextHighlightBrush}" />
    </Grid>
</UserControl>
