<Window x:Class="BananaSuisa.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BananaSuisa.App"
        xmlns:controls="clr-namespace:BananaSuisa.App.Controls"
        Title="BananaSuisa .NET Bootstrap"
        Width="1200"
        Height="800"
        MinWidth="900"
        MinHeight="640"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        
        <!-- Sidebar Esquerda -->
        <controls:SidebarMenu Grid.Column="0" />
        
        <!-- Área Direita -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            
            <!-- Área de Trabalho Dinâmica -->
            <ContentControl x:Name="MainContentArea" Grid.Row="0" Content="{Binding CurrentView}" />
            
            <!-- Footer Fixo Embaixo da Área de Trabalho -->
            <controls:StatusFooter Grid.Row="1" StatusText="Pronto" ProgressValue="0" IsProgressVisible="False" RightText="v0.1.0-alpha" />
            
            <!-- Overlay de Carregamento Global (Visível apenas quando IsLoading = True no ViewModel) -->
            <controls:LoadingOverlay Grid.RowSpan="2" Message="{Binding LoadingMessage}" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />
        </Grid>
    </Grid>
</Window>