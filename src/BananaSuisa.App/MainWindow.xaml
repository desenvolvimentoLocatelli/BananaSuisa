<Window x:Class="BananaSuisa.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BananaSuisa .NET Bootstrap"
        Width="1040"
        Height="760"
        MinWidth="900"
        MinHeight="640"
        Background="#111827"
        Foreground="#F9FAFB">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock FontSize="30"
                           FontWeight="SemiBold"
                           Text="{Binding Title}" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="#CBD5E1"
                           FontSize="14"
                           TextWrapping="Wrap"
                           Text="{Binding Subtitle}" />
            </StackPanel>

            <Border Grid.Row="2"
                    Padding="20"
                    Background="#1F2937"
                    BorderBrush="#374151"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" FontSize="18" FontWeight="SemiBold" Text="Resumo do bootstrap" />

                    <TextBlock Grid.Row="2" Text="Base directory" Foreground="#93C5FD" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding BaseDirectory}" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="4" Text="Project root" Foreground="#93C5FD" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ProjectRoot}" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="6" Text="Resources root" Foreground="#93C5FD" />
                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ResourcesRoot}" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="8" Text="Memory root" Foreground="#93C5FD" />
                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding MemoryRoot}" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="10" Text="Winget" Foreground="#93C5FD" />
                    <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding WingetPath}" TextWrapping="Wrap" />
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    Padding="20"
                    Background="#1F2937"
                    BorderBrush="#374151"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="2"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Text="Workspace inicializado" />

                    <TextBlock Grid.Row="2" Text="Resumo" Foreground="#93C5FD" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WorkspaceSummary}" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="4" Text="Data root" Foreground="#93C5FD" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DataRoot}" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="6" Text="Config path" Foreground="#93C5FD" />
                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ConfigPath}" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="8" Text="Config source" Foreground="#93C5FD" />
                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding ConfigurationSourcePath}" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="10" Text="Config summary" Foreground="#93C5FD" />
                    <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding ConfigurationSummary}" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="12" Text="Catalog summary" Foreground="#93C5FD" />
                    <TextBlock Grid.Row="12" Grid.Column="1" Text="{Binding CatalogSummary}" TextWrapping="Wrap" />

                    <ItemsControl Grid.Row="14" Grid.ColumnSpan="2" ItemsSource="{Binding WorkspaceItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="14"
                                        Background="#0F172A"
                                        BorderBrush="#334155"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding Name}" />
                                            <Border DockPanel.Dock="Right"
                                                    Padding="8,2"
                                                    Background="#1E3A8A"
                                                    CornerRadius="999">
                                                <TextBlock FontSize="11"
                                                           FontWeight="Bold"
                                                           Text="{Binding StatusText}" />
                                            </Border>
                                        </DockPanel>
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="#CBD5E1"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding Detail}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Grid Grid.Row="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold" Text="Checagens iniciais" />

                <ItemsControl Grid.Row="2" ItemsSource="{Binding Checks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12"
                                    Padding="16"
                                    Background="#0F172A"
                                    BorderBrush="#334155"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Name}" />
                                        <Border DockPanel.Dock="Right"
                                                Padding="8,2"
                                                Background="#1E3A8A"
                                                CornerRadius="999">
                                            <TextBlock FontSize="11"
                                                       FontWeight="Bold"
                                                       Text="{Binding StatusText}" />
                                        </Border>
                                    </DockPanel>
                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="#CBD5E1"
                                               TextWrapping="Wrap"
                                               Text="{Binding Detail}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Grid.Row="4"
                           Foreground="#94A3B8"
                           Text="{Binding GeneratedAt, StringFormat=Diagnostico gerado em {0}}" />
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
