<UserControl x:Class="BananaSuisa.App.Views.LogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:BananaSuisa.App.Controls"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="900">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="{StaticResource WorkspaceContentMargin}" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Style="{StaticResource HeaderTextStyle}" Text="Logs e diagnóstico" />
                <TextBlock Margin="0,6,0,0" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" TextWrapping="Wrap"
                           Text="Informações coletadas na inicialização: caminhos, workspace, buscas piloto e checagens. Dados tabulares para leitura objetiva." />
            </StackPanel>

            <controls:InfoCardWidget Grid.Row="2" CardTitle="Caminhos e ambiente">
                <controls:InfoCardWidget.CardContent>
                    <DataGrid Style="{StaticResource LogsDataGridStyle}"
                              MaxHeight="300"
                              ItemsSource="{Binding BootstrapPathRows}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Chave" Binding="{Binding Key}" Width="200" />
                            <DataGridTextColumn Header="Valor" Binding="{Binding Value}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </controls:InfoCardWidget.CardContent>
            </controls:InfoCardWidget>

            <controls:InfoCardWidget Grid.Row="4" CardTitle="Workspace e configuração">
                <controls:InfoCardWidget.CardContent>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Resumo" Foreground="{StaticResource TextHighlightBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding WorkspaceSummary}" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2" Text="Data root" Foreground="{StaticResource TextHighlightBrush}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DataRoot}" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="4" Text="Config path" Foreground="{StaticResource TextHighlightBrush}" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ConfigPath}" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="6" Text="Config source" Foreground="{StaticResource TextHighlightBrush}" />
                            <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ConfigurationSourcePath}" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="8" Text="Config summary" Foreground="{StaticResource TextHighlightBrush}" />
                            <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding ConfigurationSummary}" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="10" Text="Catalog summary" Foreground="{StaticResource TextHighlightBrush}" />
                            <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding CatalogSummary}" TextWrapping="Wrap" />
                        </Grid>

                        <TextBlock Margin="0,16,0,8" Style="{StaticResource SubHeaderTextStyle}" Text="Itens do workspace" />
                        <DataGrid Style="{StaticResource LogsDataGridStyle}"
                                  MaxHeight="300"
                                  ItemsSource="{Binding WorkspaceItems}"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Componente" Binding="{Binding Name}" Width="200" />
                                <DataGridTextColumn Header="Estado" Binding="{Binding StatusText}" Width="90" />
                                <DataGridTextColumn Header="Detalhe" Binding="{Binding Detail}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </controls:InfoCardWidget.CardContent>
            </controls:InfoCardWidget>

            <controls:InfoCardWidget Grid.Row="6" CardTitle="Busca piloto da configuração">
                <controls:InfoCardWidget.CardContent>
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Resumo" Foreground="{StaticResource TextHighlightBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding SearchSummary}" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2" Text="Consulta" Foreground="{StaticResource TextHighlightBrush}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SearchPreviewQuery}" TextWrapping="Wrap" />
                        </Grid>
                        <DataGrid Style="{StaticResource LogsDataGridStyle}"
                                  MaxHeight="300"
                                  ItemsSource="{Binding SearchPreviewItems}"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tipo" Binding="{Binding Kind}" Width="140" />
                                <DataGridTextColumn Header="Título" Binding="{Binding Title}" Width="220" />
                                <DataGridTextColumn Header="Detalhe" Binding="{Binding Detail}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </controls:InfoCardWidget.CardContent>
            </controls:InfoCardWidget>

            <controls:InfoCardWidget Grid.Row="8" CardTitle="Busca piloto do catálogo">
                <controls:InfoCardWidget.CardContent>
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Resumo" Foreground="{StaticResource TextHighlightBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding CatalogSearchSummary}" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2" Text="Catálogos" Foreground="{StaticResource TextHighlightBrush}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CatalogSummary}" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="4" Text="Consulta" Foreground="{StaticResource TextHighlightBrush}" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CatalogSearchPreviewQuery}" TextWrapping="Wrap" />
                        </Grid>
                        <DataGrid Style="{StaticResource LogsDataGridStyle}"
                                  MaxHeight="300"
                                  ItemsSource="{Binding CatalogSearchPreviewItems}"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Origem" Binding="{Binding Kind}" Width="140" />
                                <DataGridTextColumn Header="Pacote" Binding="{Binding Title}" Width="220" />
                                <DataGridTextColumn Header="Detalhe" Binding="{Binding Detail}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </controls:InfoCardWidget.CardContent>
            </controls:InfoCardWidget>

            <controls:InfoCardWidget Grid.Row="10" CardTitle="Checagens iniciais">
                <controls:InfoCardWidget.CardContent>
                    <StackPanel>
                        <DataGrid Style="{StaticResource LogsDataGridStyle}"
                                  MaxHeight="300"
                                  ItemsSource="{Binding Checks}"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Verificação" Binding="{Binding Name}" Width="220" />
                                <DataGridTextColumn Header="Estado" Binding="{Binding StatusText}" Width="90" />
                                <DataGridTextColumn Header="Detalhe" Binding="{Binding Detail}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                   Text="{Binding GeneratedAt, StringFormat=Diagnóstico gerado em {0}}" />
                    </StackPanel>
                </controls:InfoCardWidget.CardContent>
            </controls:InfoCardWidget>
        </Grid>
    </ScrollViewer>
</UserControl>
