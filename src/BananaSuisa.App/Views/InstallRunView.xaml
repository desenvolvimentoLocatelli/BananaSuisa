<UserControl x:Class="BananaSuisa.App.Views.InstallRunView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:BananaSuisa.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="640">
    <Grid Margin="28" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource HeaderTextStyle}" Text="Instalar" />

        <Border Grid.Row="2"
                Padding="20"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         MinHeight="38"
                         VerticalContentAlignment="Center"
                         Padding="10,8"
                         Background="{StaticResource CardBackgroundBrush}"
                         BorderBrush="{StaticResource WidgetBorderBrush}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         Text="{Binding WingetSearchQuery, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="2"
                        MinWidth="120"
                        Style="{StaticResource ToolbarActionButtonStyle}"
                        Content="Pesquisar"
                        Command="{Binding SearchWingetCatalogCommand}" />
            </Grid>
        </Border>

        <controls:InfoCardWidget Grid.Row="4" CardTitle="Resultados">
            <controls:InfoCardWidget.CardContent>
                <DataGrid Style="{StaticResource LogsDataGridStyle}"
                          MinHeight="200"
                          MaxHeight="320"
                          ItemsSource="{Binding WingetSearchRows}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="*" MinWidth="160" />
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="2*" MinWidth="180" />
                        <DataGridTextColumn Header="Versao" Binding="{Binding Version}" Width="100" />
                        <DataGridTextColumn Header="Fonte" Binding="{Binding Source}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </controls:InfoCardWidget.CardContent>
        </controls:InfoCardWidget>
    </Grid>
</UserControl>
