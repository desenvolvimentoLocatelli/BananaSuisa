<UserControl x:Class="BananaSuisa.App.Views.InstallRunView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:BananaSuisa.App.Controls"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="640">
    <UserControl.Resources>
        <SolidColorBrush x:Key="InstallMutedRowBackgroundBrush" Color="#2d3344" />
        <SolidColorBrush x:Key="InstallMutedRowForegroundBrush" Color="#94a3b8" />
        <Style x:Key="InstallPlanDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMutedInstalled}" Value="True">
                    <Setter Property="Background" Value="{StaticResource InstallMutedRowBackgroundBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource InstallMutedRowForegroundBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="{StaticResource WorkspacePageMargin}" Background="Transparent" VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" MinHeight="160" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <controls:SearchTextButtonRow Grid.Row="0"
                                      SearchText="{Binding WingetSearchQuery}"
                                      SearchCommand="{Binding SearchWingetCatalogCommand}"
                                      SearchButtonText="Pesquisar"
                                      WatermarkText="Buscar" />

        <Grid Grid.Row="2" VerticalAlignment="Stretch" MinHeight="160">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="260" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <!-- Pesquisa catálogo + checkbox -->
            <Grid Grid.Column="0" VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="80" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Margin="0,0,0,8"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Resultados da pesquisa" />
                <DataGrid Grid.Row="1"
                          Style="{StaticResource LogsDataGridStyle}"
                          ItemsSource="{Binding WingetCatalogSearchRows}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="40" Header="" IsReadOnly="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="*" MinWidth="100" IsReadOnly="True" />
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="*" MinWidth="100" IsReadOnly="True" />
                        <DataGridTextColumn Header="Versao" Binding="{Binding Version}" Width="72" IsReadOnly="True" />
                        <DataGridTextColumn Header="Repositório" Binding="{Binding Source}" Width="80" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Lista instalados + fila -->
            <Grid Grid.Column="2" VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="80" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Margin="0,0,0,8"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="Nesta máquina / fila de instalação" />
                <DataGrid Grid.Row="1"
                          Style="{StaticResource LogsDataGridStyle}"
                          RowStyle="{StaticResource InstallPlanDataGridRowStyle}"
                          ItemsSource="{Binding WingetSearchRows}"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="*" MinWidth="120" />
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="2*" MinWidth="140" />
                        <DataGridTextColumn Header="Versao" Binding="{Binding Version}" Width="80" />
                        <DataGridTextColumn Header="Tipo" Binding="{Binding InstallationOrigin}" Width="160" MinWidth="120" />
                        <DataGridTextColumn Header="Repositório" Binding="{Binding Source}" Width="90" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <controls:ActionButtonStrip Grid.Row="3"
                                    PrimaryButtonText="Instalar"
                                    PrimaryButtonCommand="{Binding InstallPendingPackagesCommand}"
                                    SecondaryButtonText="Cancelar"
                                    SecondaryButtonCommand="{Binding CancelInstallCommand}" />
    </Grid>
</UserControl>
