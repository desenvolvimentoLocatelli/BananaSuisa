<UserControl x:Class="BananaSuisa.App.Views.InstallOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:BananaSuisa.App.Controls"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="{StaticResource WorkspaceContentMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Cabecalho -->
            <StackPanel Grid.Row="0">
                <TextBlock Style="{StaticResource HeaderTextStyle}" Text="Visão geral" />
                <TextBlock Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" TextWrapping="Wrap"
                           Text="Verificacao e reparo dos componentes de instalacao do Windows. Use os paineis abaixo para diagnosticar e corrigir o winget e o App Installer antes de instalar ou remover programas." />
            </StackPanel>

            <!-- Card Winget -->
            <controls:InfoCardWidget Grid.Row="2" CardTitle="Winget">
                <controls:InfoCardWidget.CardContent>
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Text="Gerenciador de pacotes nativo do Windows. Verifica presenca do executavel, versao e fontes configuradas." />
                        <Border Background="{StaticResource AppBackgroundBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,14">
                            <TextBlock TextWrapping="Wrap" Text="{Binding WingetProbeSummary}" />
                        </Border>
                        <WrapPanel Orientation="Horizontal">
                            <Button Margin="0,0,8,0" Style="{StaticResource ToolbarActionButtonStyle}" MinWidth="120" Content="Verificar" Command="{Binding ProbeWingetCommand}" />
                            <Button Margin="0,0,8,0" Style="{StaticResource ToolbarActionButtonStyle}" MinWidth="180" Content="Instalar bundle oficial" Command="{Binding InstallWingetBundleCommand}" />
                            <Button Margin="0,0,0,0" Style="{StaticResource ToolbarActionButtonStyle}" MinWidth="200" Content="Reinstalar (remover + instalar)" Command="{Binding ReinstallWingetCommand}" />
                        </WrapPanel>
                    </StackPanel>
                </controls:InfoCardWidget.CardContent>
            </controls:InfoCardWidget>

            <!-- Card UWP / App Installer -->
            <controls:InfoCardWidget Grid.Row="4" CardTitle="UWP / App Installer">
                <controls:InfoCardWidget.CardContent>
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"
                                   Text="Pacotes MSIX que fornecem o winget ao Windows. Consulta Microsoft.DesktopAppInstaller e Microsoft.WindowsStore." />
                        <Border Background="{StaticResource AppBackgroundBrush}" CornerRadius="8" Padding="14" Margin="0,0,0,14">
                            <TextBlock TextWrapping="Wrap" Text="{Binding UwpProbeSummary}" />
                        </Border>
                        <WrapPanel Orientation="Horizontal">
                            <Button Margin="0,0,8,0" Style="{StaticResource ToolbarActionButtonStyle}" MinWidth="140" Content="Verificar pacotes" Command="{Binding ProbeUwpCommand}" />
                            <Button Margin="0,0,0,0" Style="{StaticResource ToolbarActionButtonStyle}" MinWidth="240" Content="Instalar / reparar App Installer" Command="{Binding InstallUwpBundleCommand}" />
                        </WrapPanel>
                    </StackPanel>
                </controls:InfoCardWidget.CardContent>
            </controls:InfoCardWidget>

            <!-- Dica -->
            <TextBlock Grid.Row="6" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" FontStyle="Italic" TextWrapping="Wrap"
                       Text="Após verificar os componentes acima, use Instalar ou Desinstalar no menu lateral para gerenciar programas." />
        </Grid>
    </ScrollViewer>
</UserControl>
