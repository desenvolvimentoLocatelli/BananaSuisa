<UserControl x:Class="BananaSuisa.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:BananaSuisa.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="400">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Margin="28" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Style="{StaticResource HeaderTextStyle}" Text="Configurações" />
                <TextBlock Margin="0,8,0,0" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" TextWrapping="Wrap"
                           Text="Preferências da aplicação serão adicionadas aqui. Caminhos e resumo vêm do workspace carregado na sessão atual." />
            </StackPanel>

            <controls:InfoCardWidget Grid.Row="2" CardTitle="Configuração carregada">
                <controls:InfoCardWidget.CardContent>
                    <StackPanel>
                        <TextBlock Margin="0,0,0,8" Foreground="{StaticResource TextHighlightBrush}" Text="Origem" />
                        <TextBlock TextWrapping="Wrap" Text="{Binding ConfigurationSourcePath}" />
                        <TextBlock Margin="0,16,0,8" Foreground="{StaticResource TextHighlightBrush}" Text="Resumo" />
                        <TextBlock TextWrapping="Wrap" Text="{Binding ConfigurationSummary}" />
                    </StackPanel>
                </controls:InfoCardWidget.CardContent>
            </controls:InfoCardWidget>
        </Grid>
    </ScrollViewer>
</UserControl>
